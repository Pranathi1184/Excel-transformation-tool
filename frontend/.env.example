# Frontend environment (copy to .env in frontend directory)

# Production only: backend API base URL (no trailing slash)
# Leave unset for local dev (Vite proxy will use /api/v1)
# VITE_API_URL=https://your-backend.onrender.com/api/v1

# Supabase (optional; app works with localStorage fallback if unset)
# Get from: https://app.supabase.com -> Project -> Settings -> API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
